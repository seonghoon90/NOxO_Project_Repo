**/dist/
**/.vite/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/.ipynb_checkpoints/
apps/frontend/
analysis/
data/raw/
data/external/
data/test/
data/NOxO/
docs/
tmp/
*.md
!apps/backend/README.md
notebook*/
**/*.ipynb
