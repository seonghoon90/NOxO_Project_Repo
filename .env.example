# 실제 값은 담당자에게 별도 문의

# APP_ENV=
# APP_NAME=

# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=
# POSTGRES_PORT=
# DATABASE_URL=
# REDIS_URL=
# SLACK_WEBHOOK_URL=

# BACKEND_PORT=
# FRONTEND_PORT=
# AIRFLOW_PORT=

# MODEL_REGISTRY_PATH=
# DATA_ROOT=
# ETL_CHUNK_SIZE=

# Kafka / Redpanda streaming simulation
# KAFKA_PORT=
# KAFKA_SENSOR_TOPIC=
# KAFKA_PRODUCE_INTERVAL_SECONDS=
# KAFKA_MAX_MESSAGES=
# KAFKA_STREAM_ENABLED=
# KAFKA_BOOTSTRAP_SERVERS=
# KAFKA_CONSUMER_GROUP_ID=
# KAFKA_BOOTSTRAP_MINUTES=
# KAFKA_BOOTSTRAP_FILE=
# STREAM_ETL_DATABASE_URL=
# STREAM_ETL_POSTGRES_HOST=
# STREAM_ETL_POSTGRES_PORT=
# KAFKA_ETL_CONSUMER_GROUP_ID=
# STREAM_ETL_BOOTSTRAP_ENABLED=
# KAFKA_ETL_AUTO_OFFSET_RESET=
# KAFKA_ETL_CONSUMER_TIMEOUT_MS=
# STREAM_ETL_RETRY_DELAY_SECONDS=

# === Reset 기능 ===
# 운영자 비밀번호. 빈 값이면 /api/reset이 503으로 거부된다.
# RESET_PASSWORD=
# RESET_BACKEND_ENABLED=true
# BACKEND_CONTAINER_NAME=noxo-backend
# PRODUCER_CONTAINER_NAME=kafka-producer
# DOCKER_HOST는 docker compose 환경에서만 자동 설정된다 (base compose에서
# tcp://docker-socket-proxy:2375 고정 주입). 로컬에서 backend를 compose 없이
# 직접 띄우는 경우 unset 상태로 두어 default unix socket 시도 → 실패 시
# NoopRestartAdapter로 폴백된다 (이 경우 /api/reset은 503).
# DOCKER_HOST=tcp://docker-socket-proxy:2375
