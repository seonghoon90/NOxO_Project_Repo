# PostgreSQL — docker/docker-compose.data.yml의 공식 DB 기준
# 실제 값은 담당자에게 별도 문의
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=

# Backend
# LOG_LEVEL=
# APP_ENV=production    # docker-compose.prod.yml 기본값. ML 모델 로드 실패 시 startup 차단.
# SENSOR_COLUMN_MAPPING= # JSON mapping for every RAW_FEATURES + TARGETS tag.
