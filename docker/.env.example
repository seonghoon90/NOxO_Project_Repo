# PostgreSQL — docker/docker-compose.data.yml의 공식 DB 기준
# 실제 값은 담당자에게 별도 문의
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=
# POSTGRES_PORT=
# ETL_CHUNK_SIZE=

# Backend
# LOG_LEVEL=
# APP_ENV=production    # docker-compose.prod.yml 기본값. ML 모델 로드 실패 시 startup 차단.
# SENSOR_COLUMN_MAPPING= # JSON mapping for every RAW_FEATURES + TARGETS tag.

# Kafka / Redpanda streaming simulation
# KAFKA_PORT=
# KAFKA_SENSOR_TOPIC=
# KAFKA_PRODUCE_INTERVAL_SECONDS=
# KAFKA_MAX_MESSAGES=
# KAFKA_STREAM_ENABLED=
# KAFKA_BOOTSTRAP_SERVERS=
# KAFKA_CONSUMER_GROUP_ID=
# KAFKA_BOOTSTRAP_MINUTES=
# KAFKA_BOOTSTRAP_FILE=
# KAFKA_ETL_CONSUMER_GROUP_ID=
# STREAM_ETL_BOOTSTRAP_ENABLED=
# KAFKA_ETL_AUTO_OFFSET_RESET=
# KAFKA_ETL_CONSUMER_TIMEOUT_MS=
# STREAM_ETL_RETRY_DELAY_SECONDS=
